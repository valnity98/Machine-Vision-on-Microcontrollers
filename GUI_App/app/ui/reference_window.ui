          <!-- ══ RIGHT: CV STM32 ══ -->
          <item>
           <widget class="QScrollArea" name="cvScrollArea">
            <property name="widgetResizable"><bool>true</bool></property>
            <property name="horizontalScrollBarPolicy"><enum>Qt::ScrollBarPolicy::ScrollBarAlwaysOff</enum></property>
            <property name="frameShape"><enum>QFrame::Shape::NoFrame</enum></property>
            <widget class="QWidget" name="cvScrollContents">
             <layout class="QVBoxLayout" name="cvScrollLayout">
              <property name="spacing"><number>6</number></property>

              <item>
               <widget class="QGroupBox" name="groupBox">
                <property name="title"><string>CV  (STM32)</string></property>
                <property name="sizePolicy">
                 <sizepolicy hsizetype="Expanding" vsizetype="Preferred">
                  <horstretch>0</horstretch><verstretch>0</verstretch>
                 </sizepolicy>
                </property>
                <layout class="QVBoxLayout" name="cvMainLayout">
                 <property name="spacing"><number>6</number></property>

                 <!-- mode status banner placeholder -->

                 <!-- action buttons -->
                 <item>
                  <layout class="QHBoxLayout">
                   <item>
                    <widget class="QPushButton" name="cvBtnGet">
                     <property name="text"><string>GET</string></property>
                     <property name="toolTip"><string>CV GET — read CV config from STM32</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QPushButton" name="btnRunCV">
                     <property name="text"><string>CV RUN</string></property>
                     <property name="toolTip"><string>Send all parameters + run CV on STM32</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QPushButton" name="btnSnapAndRunCV">
                     <property name="text"><string>Snap + CV RUN</string></property>
                     <property name="toolTip"><string>Capture RGB565 frame then run CV</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QPushButton" name="cvBtnBgCap">
                     <property name="text"><string>BG Cap</string></property>
                     <property name="toolTip"><string>Capture background reference (CV BGCAP)</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QPushButton" name="btnSaveCVResult">
                     <property name="text"><string>Save</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QPushButton" name="btnSaveDebugImages">
                     <property name="text"><string>Save Images</string></property>
                     <property name="toolTip"><string>Save Gray, Binary and Overlay images</string></property>
                    </widget>
                   </item>
                  </layout>
                 </item>

                 <!-- enabled + preset -->
                 <item>
                  <layout class="QHBoxLayout">
                   <item>
                    <widget class="QCheckBox" name="cvEnableCheck">
                     <property name="text"><string>CV Enabled</string></property>
                     <property name="checked"><bool>true</bool></property>
                    </widget>
                   </item>
                   <item><spacer><property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property><property name="sizeHint" stdset="0"><size><width>10</width><height>0</height></size></property></spacer></item>
                   <item>
                    <widget class="QLabel" name="cvPresetLabel">
                     <property name="text"><string>Preset</string></property>
                     <property name="role" stdset="0"><string>key</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QComboBox" name="cvPresetCombo">
                     <item><property name="text"><string>0 — CUSTOM</string></property></item>
                     <item><property name="text"><string>1 — FAST</string></property></item>
                     <item><property name="text"><string>2 — ROBUST</string></property></item>
                     <item><property name="text"><string>3 — ACCURATE</string></property></item>
                    </widget>
                   </item>
                   
                   <item>
                    <widget class="QLabel" name="cvSourceLabel">
                     <property name="text"><string>Source: STM32</string></property>
                     <property name="role" stdset="0"><string>hint</string></property>
                    </widget>
                   </item>
                  </layout>
                 </item>

                 <!-- CV parameters grid -->
                 <item>
                  <widget class="QGroupBox" name="cvControlGroupBox">
                   <property name="title"><string>CV Pipeline Control</string></property>
                   <layout class="QGridLayout" name="cvParamGrid" columnstretch="0,1,0,1,0,1">
                    <property name="spacing"><number>6</number></property>

                    <!-- row 0: Otsu check | Invert check -->
                    <item row="0" column="0" colspan="3">
                     <widget class="QCheckBox" name="cvOtsuCheck">
                      <property name="text"><string>Otsu (auto threshold)</string></property>
                      <property name="toolTip"><string>CV THRMODE 1=auto Otsu  0=manual slider (preview is always local)</string></property>
                     </widget>
                    </item>
                    <item row="0" column="3" colspan="3">
                     <widget class="QCheckBox" name="cvInvertCheck">
                      <property name="text"><string>Invert binary</string></property>
                      <property name="toolTip"><string>CV INV 1 — invert after threshold</string></property>
                     </widget>
                    </item>

                    <!-- row 1: Threshold slider -->
                    <item row="1" column="0">
                     <widget class="QLabel" name="cvThrLabel">
                      <property name="text"><string>Threshold</string></property>
                      <property name="role" stdset="0"><string>key</string></property>
                     </widget>
                    </item>
                    <item row="1" column="1" colspan="4">
                     <widget class="QSlider" name="cvThrSlider">
                      <property name="minimum"><number>0</number></property>
                      <property name="maximum"><number>255</number></property>
                      <property name="value"><number>128</number></property>
                      <property name="orientation"><enum>Qt::Orientation::Horizontal</enum></property>
                      <property name="toolTip"><string>CV THR 0..255 — updates local preview instantly</string></property>
                     </widget>
                    </item>
                    <item row="1" column="5">
                     <widget class="QLabel" name="cvThrValueLabel">
                      <property name="text"><string>128</string></property>
                      <property name="minimumWidth"><number>28</number></property>
                      <property name="alignment"><set>Qt::AlignmentFlag::AlignRight|Qt::AlignmentFlag::AlignVCenter</set></property>
                     </widget>
                    </item>

                    <!-- row 2: Filter | Blur kernel -->
                    <item row="2" column="0">
                     <widget class="QLabel" name="cvFilterLabel">
                      <property name="text"><string>Filter</string></property>
                      <property name="role" stdset="0"><string>key</string></property>
                     </widget>
                    </item>
                    <item row="2" column="1" colspan="2">
                     <widget class="QComboBox" name="cvFilterCombo">
                      <property name="toolTip"><string>CV FILTER: 0=OFF 1=BOX 2=MEDIAN</string></property>
                      <item><property name="text"><string>0 — OFF</string></property></item>
                      <item><property name="text"><string>1 — BOX</string></property></item>
                      <item><property name="text"><string>2 — MEDIAN</string></property></item>
                     </widget>
                    </item>
                    <item row="2" column="3">
                     <widget class="QLabel" name="cvBlurLabel">
                      <property name="text"><string>Blur k</string></property>
                      <property name="role" stdset="0"><string>key</string></property>
                     </widget>
                    </item>
                    <item row="2" column="4" colspan="2">
                     <widget class="QSpinBox" name="cvBlurSpin">
                      <property name="minimum"><number>0</number></property>
                      <property name="maximum"><number>7</number></property>
                      <property name="toolTip"><string>CV BLUR 0..7</string></property>
                     </widget>
                    </item>

                    <!-- row 3: Morph mode | Morph kernel -->
                    <item row="3" column="0">
                     <widget class="QLabel" name="cvMorphModeLabel">
                      <property name="text"><string>Morph</string></property>
                      <property name="role" stdset="0"><string>key</string></property>
                     </widget>
                    </item>
                    <item row="3" column="1" colspan="2">
                     <widget class="QComboBox" name="cvMorphModeCombo">
                      <property name="toolTip"><string>CV MORPHMODE: 0=OFF 1=OPEN 2=CLOSE 3=ERODE 4=DILATE</string></property>
                      <item><property name="text"><string>0 — OFF</string></property></item>
                      <item><property name="text"><string>1 — OPEN</string></property></item>
                      <item><property name="text"><string>2 — CLOSE</string></property></item>
                      <item><property name="text"><string>3 — ERODE</string></property></item>
                      <item><property name="text"><string>4 — DILATE</string></property></item>
                     </widget>
                    </item>
                    <item row="3" column="3">
                     <widget class="QLabel" name="cvMorphKernelLabel">
                      <property name="text"><string>Morph k</string></property>
                      <property name="role" stdset="0"><string>key</string></property>
                     </widget>
                    </item>
                    <item row="3" column="4" colspan="2">
                     <widget class="QSpinBox" name="cvMorphKernelSpin">
                      <property name="minimum"><number>0</number></property>
                      <property name="maximum"><number>7</number></property>
                      <property name="toolTip"><string>CV MORPH 0..7</string></property>
                     </widget>
                    </item>

                    <!-- row 4: CCL | Min area -->
                    <item row="4" column="0">
                     <widget class="QLabel" name="cvConnLabel">
                      <property name="text"><string>CCL Con.</string></property>
                      <property name="role" stdset="0"><string>key</string></property>
                     </widget>
                    </item>
                    <item row="4" column="1" colspan="2">
                     <widget class="QComboBox" name="cvConnCombo">
                      <property name="toolTip"><string>CV CON 4|8</string></property>
                      <item><property name="text"><string>4</string></property></item>
                      <item><property name="text"><string>8</string></property></item>
                     </widget>
                    </item>
                    <item row="4" column="3">
                     <widget class="QLabel" name="cvMinAreaLabel">
                      <property name="text"><string>Min area</string></property>
                      <property name="role" stdset="0"><string>key</string></property>
                     </widget>
                    </item>
                    <item row="4" column="4" colspan="2">
                     <widget class="QSpinBox" name="cvMinAreaSpin">
