                   <item>
                    <widget class="QPushButton" name="btnRunML">
                     <property name="text"><string>TM RUN</string></property>
                     <property name="toolTip"><string>Run TinyML inference on last RGB565 frame</string></property>
                    </widget>
                   </item>
                   <item>
                    <widget class="QPushButton" name="btnSnapAndRunML">
                     <property name="text"><string>Snap + TM RUN</string></property>
