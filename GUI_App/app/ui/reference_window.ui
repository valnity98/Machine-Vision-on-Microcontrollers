                    <item row="0" column="0"><widget class="QLabel" name="mlPredKeyLabel2"><property name="text"><string>Prediction</string></property><property name="role" stdset="0"><string>key</string></property></widget></item>
                    <item row="0" column="1"><widget class="QLabel" name="mlPredValueLabel2"><property name="text"><string>—</string></property></widget></item>
                    <item row="1" column="0"><widget class="QLabel" name="mlConfKeyLabel2"><property name="text"><string>Confidence</string></property><property name="role" stdset="0"><string>key</string></property></widget></item>
                    <item row="1" column="1"><widget class="QLabel" name="mlConfValueLabel2"><property name="text"><string>—</string></property></widget></item>
                    <item row="2" column="0"><widget class="QLabel" name="mlTimeKeyLabel"><property name="text"><string>Time</string></property><property name="role" stdset="0"><string>key</string></property></widget></item>
                    <item row="2" column="1"><widget class="QLabel" name="mlTimeValueLabel"><property name="text"><string>—</string></property></widget></item>
                    <item row="3" column="0"><widget class="QLabel" name="mlUncertainKeyLabel"><property name="text"><string>Uncertain?</string></property><property name="role" stdset="0"><string>key</string></property></widget></item>
                    <item row="3" column="1"><widget class="QLabel" name="mlUncertainLabel"><property name="text"><string>—</string></property></widget></item>
                    <item row="4" column="0"><widget class="QLabel" name="mlStatusKeyLabel"><property name="text"><string>Status</string></property><property name="role" stdset="0"><string>key</string></property></widget></item>
                    <item row="4" column="1"><widget class="QLabel" name="mlStatusLabel"><property name="text"><string>—</string></property></widget></item>
                   </layout>
